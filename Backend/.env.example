# Backend Environment Variables
# Copy this to .env and fill in your actual values

# ⚠️ CRITICAL: MongoDB Connection String
# =========================================
# FOR LOCAL DEVELOPMENT:
#   MONGODB_URI=mongodb://localhost:27017/chatapp
#
# FOR PRODUCTION (MongoDB Atlas):
#   1. Go to https://cloud.mongodb.com
#   2. Copy connection string from "Connect" button
#   3. Replace <username>, <password>, <cluster> with actual values
#   4. Ensure IP whitelist includes 0.0.0.0/0 or your Render IP
#
# IMPORTANT: Use mongodb+srv:// protocol for Atlas (it handles DNS SRV records)
# IMPORTANT: Include ?retryWrites=true&w=majority for automatic reconnection
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/chatapp?retryWrites=true&w=majority

# Groq API Key
GROQ_API_KEY=your_groq_api_key_here

# Pinecone API Key
PINECONE_API_KEY=your_pinecone_api_key_here

# JWT Secret (use a strong random string, min 32 characters)
JWT_SECRET=your_jwt_secret_key_min_32_characters_long

# Frontend URL (set after frontend is deployed)
FRONTEND_URL=https://your-frontend-url.onrender.com

# Node Environment
NODE_ENV=production

# Server Port
PORT=3001
